{
  "mcpServers": {
    "kr-financial-statements": {
      "type": "http",
      "url": "http://localhost:8000/mcp/"
    },
    "kr-financial-statements-local": {
      "type": "stdio",
      "command": "uv",
      "args": ["run", "python", "-c", "from src.mcp_server import mcp_server; mcp_server.run(transport='stdio')"],
      "env": {
        "PYTHONPATH": "."
      }
    }
  }
}
